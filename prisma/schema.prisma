generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model News {
  id        String     @id @default(cuid())
  title     String
  excerpt   String     @default("")
  body      String     @default("")
  published Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  reads     NewsRead[]
}

enum TestChoice {
  A
  B
  C
  D
}

/// O'quvchi kabinetidagi katalog bo'limi (admin tanlaydi)
enum TestCatalogCategory {
  MOCK
  MATHEMATICS
  CRITICAL_LOGIC
  ENGLISH
}

/// Katalog ustki guruh: qaysi maktab dasturi
enum ExamSchoolProgram {
  /// Prezident maktablari
  PRESIDENT_SCHOOL
  /// Ixtisoslashtirilgan maktablar
  SPECIALIZED_SCHOOL
  /// Al-Xorazmiy (faqat 4-sinf bloki testlari)
  AL_XORAZMIY
}

/// Qaysi o‘quvchi sinfi bu test uchun mo‘ljallangan
enum ExamTargetCohort {
  /// 3–4 sinf — 4→5 o‘tish tayyori
  COHORT_4_PREP
  /// 5–9 sinf — 6→7 davri va shu blok testlari
  COHORT_6_CYCLE
}

/// Ixtisos maktabda 6-sinf sikli: aniq va tabiiy fanlar yo‘nalishlari
enum SpecializedSixTrack {
  NONE
  EXACT_SCIENCES
  NATURAL_SCIENCES
}

model Test {
  id               String         @id @default(cuid())
  title            String
  subject          String         @default("")
  description      String         @default("")
  durationMinutes  Int            @default(90)
  /// Narxi (so'm), 0 = bepul / ko'rsatilmaydi
  priceSum         Int            @default(0)
  questionsCount   Int            @default(0)
  /// Kabinet / katalogda qaysi blokda ko'rsatilish
  catalogCategory  TestCatalogCategory @default(MATHEMATICS)
  /// Ust maktab guruhi — katalogdagi uchta ustun
  examSchoolProgram  ExamSchoolProgram @default(PRESIDENT_SCHOOL)
  /// Sinflar uchun band: 3–4 yoki 5–9
  examTargetCohort   ExamTargetCohort @default(COHORT_4_PREP)
  /// Faqat SPECIALIZED_SCHOOL + COHORT_6_CYCLE uchun to‘ldiriladi
  specializedSixTrack SpecializedSixTrack @default(NONE)
  isPublished      Boolean        @default(false)
  /// Masalan: saralash — 1-bosqich
  stage            String         @default("saralash")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  questions        Question[]
  attempts         TestAttempt[]
  progresses       TestProgress[]

  @@index([examSchoolProgram, examTargetCohort])
}

model Question {
  id            String     @id @default(cuid())
  testId        String
  test          Test       @relation(fields: [testId], references: [id], onDelete: Cascade)
  order         Int
  text          String
  /// Savolga biriktirilgan rasm (masalan `/uploads/questions/....jpg`), ixtiyoriy
  imageUrl      String?
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  /// Variant rasmlari (masalan `/uploads/questions/....jpg`), ixtiyoriy
  optionAImageUrl String?
  optionBImageUrl String?
  optionCImageUrl String?
  optionDImageUrl String?
  correctAnswer TestChoice
  solution      String     @default("")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([testId, order])
  @@index([testId])
}

/// O'quvchi (mobil raqam + parol + viloyat)
model User {
  id                  String         @id @default(cuid())
  phone               String         @unique
  passwordHash        String
  viloyat             String
  /// Reytingda chiqarish uchun (ism)
  firstName           String         @default("")
  /// Reytingda chiqarish uchun (familiya)
  lastName            String         @default("")
  /// Ota-ona monitoringi uchun (998XXXXXXXXX)
  parentPhone         String         @default("")
  /// Sinf (3–9). 0 = eski yozuvlar / hali tanlanmagan
  gradeLevel          Int            @default(0)
  telegramId          BigInt?        @unique
  /// Ota-ona Telegram chat ID (admin qo‘lda yoki alohida bog‘lanish — bot bilan suhbat boshlangan bo‘lishi kerak)
  parentTelegramId    BigInt?
  telegramUsername    String?
  telegramLinkedAt    DateTime?
  /// Botga /start TOKEN — bot serverdan tasdiqlash uchun
  telegramLinkToken   String?        @unique
  telegramLinkExpires DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  testAttempts        TestAttempt[]
  testProgresses      TestProgress[]
  balanceDeposits     BalanceDeposit[]
  /// Balans (so'm). Click orqali to'ldiriladi.
  balanceSum          Int            @default(0)
  supportHelpRequests SupportHelpRequest[]
  newsReads           NewsRead[]

  @@index([gradeLevel])
}

/// O‘quvchi yangilikni ochganida — ro‘yxatlarda New / O‘qilgan
model NewsRead {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newsId String
  news   News     @relation(fields: [newsId], references: [id], onDelete: Cascade)
  readAt DateTime @default(now())

  @@unique([userId, newsId])
  @@index([userId])
  @@index([newsId])
}

/// Bitta qator — admin panelidagi global sozlamalar
model AdminSiteSettings {
  id                    String   @id @default("default")
  /// 24/7 yordam: xabar yuboriladigan Telegram chat_id (shaxsiy ID yoki guruh)
  supportTelegramChatId String   @default("")
  updatedAt             DateTime @updatedAt
}

/// Kabinetdan 24/7 yordam tezligi cheklovi uchun log
model SupportHelpRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

/// Landing (mehmon) 24/7 yordam — tezlik cheklovi telefon bo'yicha
model PublicSupportHelpRequest {
  id        String   @id @default(cuid())
  phone     String
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
}

enum DepositStatus {
  PENDING
  COMPLETED
  CANCELLED
}

/// CLICK orqali balans to'ldirish — Prepare/Complete callbacklar bilan.
model BalanceDeposit {
  id           String        @id @default(cuid())
  /// Prepare javobidagi merchant_prepare_id (Click: int)
  prepareSeq   Int           @unique @default(autoincrement())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountSum    Int
  status       DepositStatus @default(PENDING)
  clickTransId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  completedAt  DateTime?

  @@index([userId])
}

/// Yechilayotgan test sessiyasi (yangilaganda davom etish + to'lovni bir marta yechish)
model TestProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId      String
  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  answersJson String   @default("{}")
  currentStep Int      @default(0)
  endsAt      DateTime
  chargedSum  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, testId])
  @@index([userId])
  @@index([testId])
}

model TestAttempt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId      String
  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  score       Int
  total       Int
  secondsUsed Int?
  /// Reyting: to‘g‘ri javoblar + tezlik bonusi (har urinishdan keyin yig‘iladi)
  rankPoints  Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([userId, testId])
  @@index([userId])
  @@index([testId])
}
