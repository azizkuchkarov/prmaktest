# PostgreSQL: avval `pmtest` bazasini yarating (masalan: createdb pmtest)
# VPS: kichik server uchun ulanishlar sonini cheklash mumkin, masalan:
# DATABASE_URL="postgresql://user:pass@host:5432/pmtest?connection_limit=5&pool_timeout=10"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pmtest"

ADMIN_PASSWORD="o'zgartiring"
ADMIN_SECRET="kamida-32-belgili-maxfiy-kalit-qiymatini-qo'ying"

# O'quvchi sessiyasi (JWT, kamida 16 belgi)
STUDENT_SESSION_SECRET="boshqa-uzun-maxfiy-kalit-16+"

# Telegram Login Widget va yangilik xabarlari — BotFather dan
TELEGRAM_BOT_TOKEN=""

# Sayt manzili — session cookie `secure` va Telegram havolalari uchun. Production: https://testpm.uz
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Telegram matnlarida brend (ixtiyoriy, masalan testpm.uz)
# NEXT_PUBLIC_SITE_LABEL="testpm.uz"

# Bot serveridan API (Bearer kalit, kamida 16 belgi):
# - POST /api/telegram/confirm-link — tanada token, telegramId (/start havolasi)
# - POST /api/telegram/link-by-phone — tanada phone, telegramId (kontakt ulashganda)
TELEGRAM_BOT_API_SECRET="bot-api-maxfiy-kalit-16+"

# Ixtiyoriy: bot (npm run bot:link) lokalda `npm run dev` bilan — Windows da IPv6 uchun 127.0.0.1 qo‘ying:
# TELEGRAM_LINK_SITE_URL="http://127.0.0.1:3000"

# Ixtiyoriy: ixcham chiqish (.next/standalone + node server.js). PM2 + `next start` da odatda kerak emas.
# NEXT_STANDALONE=1

# Telefon orqali LAN dev HMR: vergul bilan bir nechta IP/host
# NEXT_DEV_EXTRA_ORIGINS=192.168.1.10,10.0.0.5

# CLICK Merchant (my.click.uz kabinetidan). Callback URL: {NEXT_PUBLIC_APP_URL}/api/payment/click
CLICK_MERCHANT_ID=""
CLICK_SERVICE_ID=""
CLICK_SECRET_KEY=""
# Ixtiyoriy: CLICK formadagi merchant_user_id (bo‘sh qoldirish mumkin)
# CLICK_MERCHANT_USER_ID=""

